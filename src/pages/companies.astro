const sectors = [...new Set(companies.map(c => c.sector))];
---

<Layout
  title="台灣前 50 大企業泡泡圖"
  description="以互動式 D3 泡泡圖呈現台灣前 50 大企業的市值、營收與產業分佈"
>
  <main class="companies-page">
    <div class="hero">
      <h1>🏢 台灣前 50 大企業</h1>
      <p class="subtitle">
        以市值為圓面積的互動泡泡圖，一目了然台灣產業版圖。<br />
        泡泡越大 = 市值越高，顏色代表產業，懸停查看詳情。
      </p>
      <p class="data-note">
        📊 資料來源：TWSE、各公司年報、公開資訊觀測站（2025 年度近似值）<br />
        💡 點擊產業標籤可篩選；泡泡可拖曳
      </p>
    </div>

    <div class="controls">
      <div class="size-toggle">
        <label>泡泡大小依據：</label>
        <button class="toggle-btn active" data-mode="marketCap">市值</button>
        <button class="toggle-btn" data-mode="revenue">營收</button>
        <button class="toggle-btn" data-mode="employees">員工數</button>
      </div>
      <div class="sector-filters">
        <button class="sector-btn active" data-sector="all">全部</button>
        {sectors.map(s => (
          <button
            class="sector-btn"
            data-sector={s}
            style={`--sector-color: ${sectorColors[s] || '#888'}`}
          >
            <span class="sector-dot" style={`background: ${sectorColors[s] || '#888'}`}></span>
            {s}
          </button>
        ))}
      </div>
    </div>

    <div id="bubble-chart"></div>

    <div class="table-section">
      <h2>📋 完整排名</h2>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>#</th>
              <th>企業</th>
              <th>產業</th>
              <th>市值（億 TWD）</th>
              <th>營收（億 TWD）</th>
              <th>員工數</th>
              <th>成立</th>
            </tr>
          </thead>
          <tbody>
            {companies.map((c, i) => (
              <tr>
                <td>{i + 1}</td>
                <td><strong>{c.name}</strong></td>
                <td>
                  <span class="sector-tag" style={`background: ${sectorColors[c.sector] || '#888'}20; color: ${sectorColors[c.sector] || '#888'}; border: 1px solid ${sectorColors[c.sector] || '#888'}40`}>
                    {c.sector}
                  </span>
                </td>
                <td>{c.marketCap.toLocaleString()}</td>
                <td>{c.revenue.toLocaleString()}</td>
                <td>{c.employees.toLocaleString()}</td>
                <td>{c.founded}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <div class="insights">
      <h2>🔍 關鍵洞察</h2>
      <div class="insight-grid">
        <div class="insight-card">
          <div class="insight-number">39%</div>
          <div class="insight-label">台積電佔台股總市值比重</div>
          <div class="insight-detail">一家公司 ≈ 其餘 1,000 多家上市公司的 2/3</div>
        </div>
        <div class="insight-card">
          <div class="insight-number">72%</div>
          <div class="insight-label">前 50 大佔台股總市值</div>
          <div class="insight-detail">台灣股市高度集中於大型企業</div>
        </div>
        <div class="insight-card">
          <div class="insight-number">12 家</div>
          <div class="insight-label">半導體相關企業入榜</div>
          <div class="insight-detail">印證「矽盾」之名——半導體是台灣的國防</div>
        </div>
        <div class="insight-card">
          <div class="insight-number">9 家</div>
          <div class="insight-label">金融業入榜前 50</div>
          <div class="insight-detail">金控整併後，金融業成為穩定力量</div>
        </div>
      </div>
    </div>

    <div class="methodology">
      <h2>📝 說明</h2>
      <p>
        本圖表收錄台灣市值前 50 大企業（含少數未上市重要企業如長春石化、奇美實業），
        市值與營收為 2025 年度近似值，僅供趨勢參考，不構成投資建議。
        完整即時數據請查閱 <a href="https://www.twse.com.tw/" target="_blank" rel="noopener">臺灣證券交易所</a>。
      </p>
      <p>
        📖 延伸閱讀：
        <a href="/economy/經濟奇蹟">台灣經濟奇蹟</a> ｜
        <a href="/economy/新創生態系">新創生態系</a> ｜
        <a href="/economy/台灣金融科技發展">金融科技發展</a>
      </p>
    </div>
  </main>

  <script define:vars={{ companies, sectorColors }}>
    const data = companies;
    const colors = sectorColors;

    const script = document.createElement('script');
    script.src = 'https://d3js.org/d3.v7.min.js';
    script.onload = () => initBubbleChart(data, colors);
    document.head.appendChild(script);

    function initBubbleChart(data, colors) {
      const container = document.getElementById('bubble-chart');
      const width = container.clientWidth;
      const height = Math.max(600, window.innerHeight * 0.6);

      let currentMode = 'marketCap';
      let currentSector = 'all';

      const svg = d3
        .select('#bubble-chart')
        .append('svg')
        .attr('width', width)
        .attr('height', height)
        .attr('viewBox', `0 0 ${width} ${height}`);

      const tooltip = d3
        .select('#bubble-chart')
        .append('div')
        .attr('class', 'tooltip')
        .style('opacity', 0);

      function getValue(d) {
        return d[currentMode] || 0;
      }

      function getRadius(d) {
        const val = getValue(d);
        const maxVal = d3.max(data, getValue);
        const minR = 18;
        const maxR = Math.min(width, height) * 0.18;
        return minR + (maxR - minR) * Math.sqrt(val / maxVal);
      }

      const simulation = d3
        .forceSimulation(data)
        .force('center', d3.forceCenter(width / 2, height / 2))
        .force('charge', d3.forceManyBody().strength(5))
        .force(
          'collision',
          d3.forceCollide().radius((d) => getRadius(d) + 2).strength(0.8)
        )
        .force('x', d3.forceX(width / 2).strength(0.05))
        .force('y', d3.forceY(height / 2).strength(0.05));

      const nodes = svg
        .selectAll('g.node')
        .data(data)
        .join('g')
        .attr('class', 'node')
        .call(
          d3
            .drag()
            .on('start', (e, d) => {
              if (!e.active) simulation.alphaTarget(0.3).restart();
              d.fx = d.x;
              d.fy = d.y;
            })
            .on('drag', (e, d) => {
              d.fx = e.x;
              d.fy = e.y;
            })
            .on('end', (e, d) => {
              if (!e.active) simulation.alphaTarget(0);
              d.fx = null;
              d.fy = null;
            })
        );

      const circles = nodes
        .append('circle')
        .attr('r', (d) => getRadius(d))
        .attr('fill', (d) => colors[d.sector] || '#888')
        .attr('fill-opacity', 0.8)
        .attr('stroke', (d) => colors[d.sector] || '#888')
        .attr('stroke-width', 2)
        .attr('stroke-opacity', 0.3)
        .style('cursor', 'grab');

      const labels = nodes
        .append('text')
        .attr('text-anchor', 'middle')
        .attr('dominant-baseline', 'central')
        .attr('fill', '#fff')
        .attr('font-weight', '600')
        .attr('pointer-events', 'none')
        .each(function (d) {
          const r = getRadius(d);
          const el = d3.select(this);
          const shortName = d.name.split(' ')[0];
          if (r > 50) {
            el.append('tspan').attr('x', 0).attr('dy', '-0.4em').attr('font-size', `${Math.min(14, r / 4)}px`).text(shortName);
            el.append('tspan').attr('x', 0).attr('dy', '1.3em').attr('font-size', `${Math.min(11, r / 5)}px`).attr('fill-opacity', 0.8).text(d.marketCap.toLocaleString() + ' 億');
          } else if (r > 28) {
            el.attr('font-size', `${Math.min(11, r / 3.5)}px`).text(shortName);
          } else {
            el.attr('font-size', '9px').text(shortName.slice(0, 2));
          }
        });

      nodes
        .on('mouseover', (e, d) => {
          const modeLabel = { marketCap: '市值', revenue: '營收', employees: '員工數' };
          tooltip.transition().duration(200).style('opacity', 1);
          tooltip.html(`
            <strong>${d.name}</strong><br/>
            <span style="color:${colors[d.sector]||'#888'}">● ${d.sector}</span><br/>
            市值：${d.marketCap.toLocaleString()} 億 TWD<br/>
            營收：${d.revenue.toLocaleString()} 億 TWD<br/>
            員工：${d.employees.toLocaleString()} 人<br/>
            成立：${d.founded} 年
          `)
            .style('left', e.pageX + 15 + 'px')
            .style('top', e.pageY - 10 + 'px');
          d3.select(e.currentTarget).select('circle').attr('fill-opacity', 1).attr('stroke-width', 3);
        })
        .on('mouseout', (e) => {
          tooltip.transition().duration(300).style('opacity', 0);
          d3.select(e.currentTarget).select('circle').attr('fill-opacity', 0.8).attr('stroke-width', 2);
        });

      simulation.on('tick', () => {
        nodes.attr('transform', (d) => {
          d.x = Math.max(getRadius(d), Math.min(width - getRadius(d), d.x));
          d.y = Math.max(getRadius(d), Math.min(height - getRadius(d), d.y));
          return `translate(${d.x},${d.y})`;
        });
      });

      // Toggle size mode
      document.querySelectorAll('.toggle-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.toggle-btn').forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');
          currentMode = btn.dataset.mode;
          updateBubbles();
        });
      });

      // Sector filter
      document.querySelectorAll('.sector-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.sector-btn').forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');
          currentSector = btn.dataset.sector;
          updateBubbles();
        });
      });

      function updateBubbles() {
        circles
          .transition()
          .duration(600)
          .attr('r', (d) => {
            if (currentSector !== 'all' && d.sector !== currentSector) return 0;
            return getRadius(d);
          })
          .attr('fill-opacity', (d) => {
            if (currentSector !== 'all' && d.sector !== currentSector) return 0;
            return 0.8;
          });

        labels
          .transition()
          .duration(600)
          .attr('fill-opacity', (d) => {
            if (currentSector !== 'all' && d.sector !== currentSector) return 0;
            return 1;
          });

        simulation
          .force(
            'collision',
            d3.forceCollide().radius((d) => {
              if (currentSector !== 'all' && d.sector !== currentSector) return 0;
              return getRadius(d) + 2;
            }).strength(0.8)
          )
          .alpha(0.6)
          .restart();
      }
    }
  </script>

  <style>
    .companies-page {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }

    .hero {
      text-align: center;
      margin-bottom: 2rem;
    }

    .hero h1 {
      font-size: 2.2rem;
      margin-bottom: 0.5rem;
    }

    .subtitle {
      font-size: 1.1rem;
      color: #555;
      line-height: 1.6;
    }

    .data-note {
      font-size: 0.85rem;
      color: #888;
      margin-top: 0.5rem;
    }

    .controls {
      margin-bottom: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .size-toggle {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-wrap: wrap;
    }

    .size-toggle label {
      font-weight: 600;
      font-size: 0.9rem;
    }

    .toggle-btn {
      padding: 0.4rem 1rem;
      border: 2px solid #ddd;
      border-radius: 20px;
      background: #fff;
      cursor: pointer;
      font-size: 0.85rem;
      transition: all 0.2s;
    }

    .toggle-btn.active {
      background: #2563eb;
      color: #fff;
      border-color: #2563eb;
    }

    .sector-filters {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
    }

    .sector-btn {
      padding: 0.3rem 0.8rem;
      border: 1px solid #ddd;
      border-radius: 15px;
      background: #fff;
      cursor: pointer;
      font-size: 0.8rem;
      display: flex;
      align-items: center;
      gap: 0.3rem;
      transition: all 0.2s;
    }

    .sector-btn.active {
      background: #f0f0f0;
      border-color: #999;
      font-weight: 600;
    }

    .sector-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      display: inline-block;
    }

    #bubble-chart {
      position: relative;
      width: 100%;
      min-height: 600px;
      border: 1px solid #eee;
      border-radius: 12px;
      overflow: hidden;
      background: #fafafa;
      margin-bottom: 2rem;
    }

    #bubble-chart svg {
      display: block;
    }

    :global(.tooltip) {
      position: absolute;
      background: rgba(0, 0, 0, 0.85);
      color: #fff;
      padding: 10px 14px;
      border-radius: 8px;
      font-size: 0.85rem;
      line-height: 1.5;
      pointer-events: none;
      z-index: 100;
      max-width: 280px;
    }

    .table-section {
      margin-top: 2rem;
    }

    .table-section h2 {
      margin-bottom: 1rem;
