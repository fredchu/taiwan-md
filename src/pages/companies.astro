  '石化': '#8b5cf6',
  '電子零組件': '#06b6d4',
  '電信': '#ec4899',
  '食品': '#f97316',
  '航運': '#0ea5e9',
  '電腦品牌': '#6366f1',
  '鋼鐵': '#64748b',
  '水泥': '#a78bfa',
  '光學': '#14b8a6',
  '自行車': '#22c55e',
  '紡織/化纖': '#d946ef',
  '交通': '#0891b2',
  '消費電子': '#e11d48',
  '工業電腦': '#2563eb',
  '機殼': '#7c3aed',
  '石化/面板': '#9333ea',
  '伺服器': '#0284c7',
  'PCB': '#059669',
  '精密機械': '#b45309',
