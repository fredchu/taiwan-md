---
import Layout from '../layouts/Layout.astro';

const sounds = [
  {
    file: 'taichung-green-museumbrary-crickets.mp3',
    location: '台中綠美圖',
    locationEn: 'Taichung Green Museumbrary',
    description: '夜晚蟋蟀聲',
    descriptionEn: 'Evening cricket chorus',
    contributor: 'bugnimusic',
    date: '2026-03',
    icon: '🦗',
  },
  {
    file: 'taipei-nangang-garbage-truck-melody-maidens-prayer.mp3',
    location: '台北南港',
    locationEn: 'Taipei Nangang',
    description: '垃圾車音樂（少女的祈禱）',
    descriptionEn: "Garbage truck melody (Maiden's Prayer)",
    contributor: 'x1001000',
    date: '2021-03',
    icon: '🚛',
  },
];

const wishlist = [
  { icon: '🚛', text: '各縣市垃圾車音樂', textEn: 'Garbage truck melodies (regional variations)' },
  { icon: '🏯', text: '廟會北管鑼鼓', textEn: 'Temple Beiguan drums' },
  { icon: '🌊', text: '東海岸浪聲', textEn: 'East coast waves' },
  { icon: '🏙️', text: '夜市叫賣', textEn: 'Night market vendors' },
  { icon: '🐦', text: '山林鳥鳴', textEn: 'Mountain birdsong' },
  { icon: '🦗', text: '各地蟲鳴', textEn: 'Insect choruses across Taiwan' },
  { icon: '🚂', text: '火車進站音樂', textEn: 'Train station jingles' },
];
---

<Layout
  title="台灣聲景 Taiwan Soundscape — Taiwan.md"
  description="用耳朵認識台灣——田野錄音收集計畫，收錄蟋蟀、垃圾車、廟會、浪聲等台灣獨有的聲音風景"
>
  <div class="soundscape-page">

    <section class="hero">
      <div class="hero-inner">
        <p class="hero-kicker">🎧 Soundscape</p>
        <h1>台灣聲景</h1>
        <p class="hero-subtitle">
          有些故事，用耳朵聽比用眼睛看更真實。<br />
          <span class="hero-subtitle-en">Some stories are best told through ears.</span>
        </p>
        <p class="hero-count">{sounds.length} recordings collected</p>
      </div>
    </section>

    <section class="sound-library">
      <div class="section-inner">
        <h2>🎙️ 聲音圖書館 <span class="section-label">Sound Library</span></h2>
        <div class="sound-grid">
          {sounds.map((sound) => (
            <div class="sound-card">
              <div class="sound-icon">{sound.icon}</div>
              <div class="sound-info">
                <h3>{sound.location}</h3>
                <p class="sound-location-en">{sound.locationEn}</p>
                <p class="sound-desc">{sound.description}</p>
                <p class="sound-desc-en">{sound.descriptionEn}</p>
                <div class="sound-meta">
                  <a href={`https://github.com/${sound.contributor}`} target="_blank" rel="noopener" class="contributor">
                    @{sound.contributor}
                  </a>
                  <span class="sound-date">{sound.date}</span>
                </div>
              </div>
              <audio controls preload="none" class="sound-player">
                <source src={`/assets/sounds/${sound.file}`} type="audio/mpeg" />
              </audio>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="wishlist">
      <div class="section-inner">
        <h2>📋 想收集的聲音 <span class="section-label">Wishlist</span></h2>
        <p class="wishlist-intro">
          這些是我們特別想收錄的台灣聲景。如果你身邊剛好有，歡迎錄下來貢獻！
        </p>
        <div class="wishlist-grid">
          {wishlist.map((item) => (
            <div class="wishlist-card">
              <span class="wishlist-icon">{item.icon}</span>
              <div>
                <p class="wishlist-text">{item.text}</p>
                <p class="wishlist-text-en">{item.textEn}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="contribute-cta">
      <div class="section-inner">
        <h2>🎤 貢獻你的錄音</h2>
        <p>
          用手機錄下 30 秒到 2 分鐘的台灣聲景，轉成 MP3，開一個 PR 就好。<br />
          不會用 GitHub？直接<a href="mailto:cheyu.wu@monoame.com">寄信給我們</a>，附上錄音檔和地點描述。
        </p>
        <div class="cta-steps">
          <div class="step"><span class="step-num">1</span> 錄下聲音（30s – 2min）</div>
          <div class="step"><span class="step-num">2</span> 轉成 MP3（128kbps+）</div>
          <div class="step"><span class="step-num">3</span> 開 PR 或寄信給我們</div>
        </div>
        <a href="/contribute" class="cta-btn">前往貢獻頁面 →</a>
      </div>
    </section>

  </div>
</Layout>

<style>
  .soundscape-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }

  /* Hero */
  .hero {
    text-align: center;
    padding: 4rem 0 3rem;
  }
  .hero-kicker {
    font-size: 0.9rem;
    color: #ABC468;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }
  .hero h1 {
    font-size: 2.8rem;
    margin: 0.3rem 0;
  }
  .hero-subtitle {
    font-size: 1.15rem;
    color: #a1a1aa;
    line-height: 1.8;
    margin-top: 0.8rem;
  }
  .hero-subtitle-en {
    font-size: 0.95rem;
    color: #71717a;
    font-style: italic;
  }
  .hero-count {
    margin-top: 1rem;
    font-size: 0.85rem;
    color: #52525b;
    letter-spacing: 0.1em;
  }

  /* Section */
  .section-inner {
    margin-bottom: 3rem;
  }
  .section-inner h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .section-label {
    font-size: 0.85rem;
    color: #71717a;
    font-weight: 400;
  }

  /* Sound Grid */
  .sound-grid {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  .sound-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 1.5rem;
    transition: border-color 0.2s;
  }
  .sound-card:hover {
    border-color: rgba(171, 196, 104, 0.3);
  }
  .sound-icon {
    font-size: 2rem;
    margin-bottom: 0.8rem;
  }
  .sound-info h3 {
    font-size: 1.2rem;
    margin: 0 0 0.15rem;
  }
  .sound-location-en {
    font-size: 0.85rem;
    color: #71717a;
    margin: 0 0 0.6rem;
  }
  .sound-desc {
    color: #d4d4d8;
    margin: 0 0 0.15rem;
  }
  .sound-desc-en {
    font-size: 0.85rem;
    color: #71717a;
    margin: 0 0 0.8rem;
  }
  .sound-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.85rem;
    margin-bottom: 1rem;
  }
  .contributor {
    color: #ABC468;
    text-decoration: none;
  }
  .contributor:hover {
    text-decoration: underline;
  }
  .sound-date {
    color: #52525b;
  }
  .sound-player {
    width: 100%;
    height: 40px;
    border-radius: 8px;
  }
  .sound-player::-webkit-media-controls-panel {
    background: rgba(255, 255, 255, 0.05);
  }

  /* Wishlist */
  .wishlist-intro {
    color: #a1a1aa;
    margin-bottom: 1.2rem;
  }
  .wishlist-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 0.8rem;
  }
  .wishlist-card {
    display: flex;
    align-items: flex-start;
    gap: 0.8rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 8px;
    padding: 1rem;
  }
  .wishlist-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }
  .wishlist-text {
    margin: 0;
    color: #d4d4d8;
  }
  .wishlist-text-en {
    margin: 0.2rem 0 0;
    font-size: 0.82rem;
    color: #71717a;
  }

  /* CTA */
  .contribute-cta {
    text-align: center;
    padding: 2rem 0;
  }
  .contribute-cta p {
    color: #a1a1aa;
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }
  .contribute-cta a:not(.cta-btn) {
    color: #ABC468;
  }
  .cta-steps {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  .step {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #d4d4d8;
    font-size: 0.95rem;
  }
  .step-num {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(171, 196, 104, 0.15);
    color: #ABC468;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    font-weight: 600;
    flex-shrink: 0;
  }
  .cta-btn {
    display: inline-block;
    padding: 0.75rem 2rem;
    background: rgba(171, 196, 104, 0.12);
    border: 1px solid rgba(171, 196, 104, 0.3);
    border-radius: 8px;
    color: #ABC468;
    text-decoration: none;
    font-size: 0.95rem;
    transition: all 0.2s;
  }
  .cta-btn:hover {
    background: rgba(171, 196, 104, 0.2);
    border-color: rgba(171, 196, 104, 0.5);
  }

  @media (max-width: 600px) {
    .hero h1 { font-size: 2rem; }
    .cta-steps { flex-direction: column; align-items: center; }
  }
</style>
